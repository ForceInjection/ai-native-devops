[0.001, "o", "───────\r\u001b[1B\u001b[39m \u001b[38;2;177;185;249m\u001b[1mBash command\u001b[22m\u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\r\n\u001b[4Gecho\u001b[9G\"===\u001b[14G全链路结构对比\u001b[29G===\"\u001b[34G&&\u001b[37Gecho\u001b[42G\"\"\u001b[45G&&\u001b[48Gecho\u001b[53G\"---\u001b[58G文件大小对比\u001b[71G---\"\u001b[76G&&\u001b[79Gfor\u001b[83Gf\u001b[85Gin\u001b[88G02-prd.md\u001b[98G03-ddd-modeling.md\u001b[117G05-code-structure.md;\u001b[139Gdo\u001b[142Gsrc_size=$(wc\u001b[156G-c\u001b[159G<\u001b[161Gcloudpilot-case/$f\u001b[180G2>/dev/null\u001b[192G||\u001b[195Gecho\u001b[200G\"N/A\");\r\r\n\u001b[4Gout_size=$(wc\u001b[18G-c\u001b[21G<\u001b[23G/tmp/$f\u001b[31G2>/dev/null\u001b[43G||\u001b[46Gecho\u001b[51G\"N/A\");\u001b[59Gecho\u001b[64G\"$f\u001b[69G原版:\u001b[75G${src_size}B\u001b[89G新版:\u001b[95G${out_size}B\";\u001b[110Gdone\u001b[115G&&\u001b[118Gecho\u001b[123G\"\"\u001b[126G&&\u001b[129Gecho\u001b[134G\"---\u001b[139GRequirement\u001b[151G数量对比\u001b[160G---\"\u001b[165G&&\u001b[168Gecho\u001b[173G\"原版\u001b[179GRequirement:\"\u001b[193G&&\u001b[196Ggrep\u001b[201G-rc\u001b[205G'###\r\r\n\u001b[4GRequirement:'\u001b[18Gcloudpilot-case/04-openspec/specs/\u001b[53G2>/dev/null\u001b[65G&&\u001b[68Gecho\u001b[73G\"新版\u001b[79GRequirement:\"\u001b[93G&&\u001b[96Ggrep\u001b[101G-rc\u001b[105G'###\u001b[110GRequirement:'\u001b[124G/tmp/04-openspec/specs/\u001b[148G2>/dev/null\u001b[160G&&\u001b["]
[0.000, "o", "163Gecho\u001b[168G\"\"\u001b[171G&&\u001b[174Gecho\u001b[179G\"---\u001b[184GScenario\u001b[193G数量对比\u001b[202G---\"\u001b[207G&&\r\r\n\u001b[4Gecho\u001b[9G\"原版\u001b[15GScenario:\"\u001b[26G&&\u001b[29Ggrep\u001b[34G-rc\u001b[38G'####\u001b[44GScenario:'\u001b[55Gcloudpilot-case/04-openspec/specs/\u001b[90G2>/dev/null\u001b[102G&&\u001b[105Gecho\u001b[110G\"新版\u001b[116GScenario:\"\u001b[127G&&\u001b[130Ggrep\u001b[135G-rc\u001b[139G'####\u001b[145GScenario:'\u001b[156G/tmp/04-openspec/specs/\u001b[180G2>/dev/null\r\r\n\u001b[4G\u001b[38;2;153;153;153mFull\u001b[9Gcomparison\u001b[20Gbetween\u001b[28G/tmp\u001b[33Gand\u001b[37Gcloudpilot-case\u001b[39m\r\r\n\r\r\n\u001b[2GContains\u001b[11Gsimple_expansion\r\r\n\r\r\n\u001b[2GDo\u001b[5Gyou\u001b[9Gwant\u001b[14Gto\u001b[17Gproceed?\r\r\n\u001b[2G\u001b[38;2;177;185;249m❯\u001b[4G\u001b[38;2;153;153;153m1.\u001b[7G\u001b[38;2;177;185;249mYes\u001b[39m\r\r\n\u001b[4G\u001b[38;2;153;153;153m2.\u001b[7G\u001b[39mNo\r\r\n\r\r\n\u001b[2G\u001b[38;2;153;153;153mEsc\u001b[6Gto\u001b[9Gcancel\u001b[16G·\u001b[18GTab\u001b[22Gto\u001b[25Gamend\u001b[31G·\u001b[33Gctrl+e\u001b[40Gto\u001b[43Gexplain\u001b[39m\r\r\n\u001b[1C\u001b[4A\u001b[?2026l"]
